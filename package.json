{
  "name": "blockchain-root",
  "version": "1.0.0",
  "scripts": {
    "start": "cd frontend && npm start",
    "backend": "cd backend-js && npm start",
    "dev": "concurrently \"npm run start\" \"npm run backend\"",
    "install-all": "npm install && cd frontend && npm install && cd ../backend-js && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
